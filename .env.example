# ============================================================
# AI COMMERCE PLATFORM — Environment Variables (example)
# Copy to .env and fill real values. NEVER commit .env.
# ============================================================

# ---- Runtime ----
NODE_ENV=development

# ---- Database (PostgreSQL 15 + pgvector) ----
POSTGRES_USER=commerce
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=ai_commerce
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Prisma connection string (compose uses host "postgres")
DATABASE_URL=postgresql://commerce:change_me_local_only@localhost:5432/ai_commerce?schema=public

# ---- Backend ----
BACKEND_PORT=3001
# JWT secrets — MUST be long random strings in production
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=604800      # seconds (7 days)
# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:3000
# Global API rate limit (requests per minute per IP)
RATE_LIMIT_PER_MIN=120
# Integration credential encryption key (32 bytes, base64 or 64-hex).
# If empty, derived from JWT secret (dev only). MUST be set in production.
INTEGRATION_ENC_KEY=
# Directory for uploaded media (local storage; use S3/CDN in production).
UPLOAD_DIR=

# ---- AI Gateway (LiteLLM / OpenRouter compatible) ----
# If unset, AI agents run in graceful-fallback mode (no fake data).
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_MODEL_DEFAULT=gemini-flash
AI_MODEL_CONTENT=qwen-3
AI_MODEL_STRATEGY=claude-sonnet
AI_DAILY_TOKEN_BUDGET=10000000

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# ---- Seed (initial super admin, dev only) ----
SEED_ADMIN_EMAIL=admin@commerce.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_TENANT_NAME=Demo Store
