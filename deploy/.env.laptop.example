# ============================================================
# AI COMMERCE — env khi chạy trên LAPTOP (copy → deploy/.env.laptop, chmod 600)
# CÁCH LÀM: bê nguyên giá trị từ deploy/.env.prod của VPS sang, rồi thêm CF_TUNNEL_TOKEN.
# ⚠️ TUYỆT ĐỐI KHÔNG commit file .env.laptop. KHÔNG dán token/secret vào chat.
# ============================================================

# ---- Domain (giữ nguyên để web image bake-sẵn còn khớp) ----
DOMAIN=store.picklefund.uk

# ---- Database (nội bộ; không expose host port) ----
POSTGRES_USER=commerce
POSTGRES_PASSWORD=__COPY_TU_ENV_PROD__
POSTGRES_DB=ai_commerce

# ---- Auth secrets: COPY Y NGUYÊN từ .env.prod để session cũ còn hiệu lực ----
JWT_ACCESS_SECRET=__COPY_TU_ENV_PROD__
JWT_REFRESH_SECRET=__COPY_TU_ENV_PROD__
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ---- ⚠️ BẮT BUỘC copy Y NGUYÊN từ .env.prod ----
# Nếu đổi key này, mật khẩu SMTP Email + khoá Shopee đã mã hoá sẽ KHÔNG giải mã được.
INTEGRATION_ENC_KEY=__COPY_TU_ENV_PROD__

# ---- Rate limit ----
RATE_LIMIT_PER_MIN=120

# ---- AI gateway / Shopee (copy nếu VPS có dùng; để trống nếu không) ----
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_MODEL_DEFAULT=gemini-flash
AI_MODEL_CONTENT=qwen-3
AI_MODEL_STRATEGY=claude-sonnet
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_API_BASE=https://partner.shopeemobile.com
SHOPEE_REDIRECT_URL=https://store.picklefund.uk/api/v1/marketplace/shopee/callback

# ---- Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → tunnel của bạn) ----
# Chỉ có trên laptop. Rất nhạy cảm — như mật khẩu.
CF_TUNNEL_TOKEN=__DAN_TOKEN_TUNNEL_O_DAY__

# ---- Tag image muốn chạy (mặc định latest) ----
IMAGE_TAG=latest
