# ============================================================
# AI COMMERCE PLATFORM — PRODUCTION env (copy to deploy/.env.prod)
# Generate strong secrets with:  bash deploy/gen-secrets.sh
# NEVER commit deploy/.env.prod.
# ============================================================

# ---- Domain & TLS (Caddy auto-HTTPS) ----
DOMAIN=commerce.example.com
ACME_EMAIL=admin@example.com

# ---- Database (internal only; not published to host) ----
POSTGRES_USER=commerce
POSTGRES_PASSWORD=__CHANGE_ME_strong_random__
POSTGRES_DB=ai_commerce

# ---- Auth secrets (MUST be long random; see gen-secrets.sh) ----
JWT_ACCESS_SECRET=__CHANGE_ME_64_hex__
JWT_REFRESH_SECRET=__CHANGE_ME_64_hex__
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ---- Integration credential encryption (32-byte, base64 or 64-hex) ----
INTEGRATION_ENC_KEY=__CHANGE_ME_32byte_base64__

# ---- Rate limit ----
RATE_LIMIT_PER_MIN=120

# ---- AI gateway (optional; leave empty to run agents in graceful-fallback mode) ----
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_MODEL_DEFAULT=gemini-flash
AI_MODEL_CONTENT=qwen-3
AI_MODEL_STRATEGY=claude-sonnet
